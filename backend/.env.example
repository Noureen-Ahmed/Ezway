# ============================================================
# Railway Environment Variables - Set these in Railway Dashboard
# ============================================================

# Database (Railway provides this automatically via Variable Reference)
# In Railway: set DATABASE_URL = ${{MySQL.MYSQL_URL}}
DATABASE_URL=mysql://root:PASSWORD@mysql.railway.internal:3306/railway

# Server
PORT=3000
NODE_ENV=production

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Admin seeding
ADMIN_EMAIL=admin@college.edu
ADMIN_PASSWORD=admin123

# Cloudflare R2 Storage
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-YOUR_HASH.r2.dev
R2_BUCKET_NAME=college-guide

# Email (SMTP - Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# EmailJS (optional)
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=

# Firebase (optional - for push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
