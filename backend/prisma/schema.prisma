generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Faculty {
  id          String       @id @default(cuid())
  name        String       @unique
  nameAr      String?      @map("name_ar")
  code        String       @unique
  description String?      @db.LongText
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  departments Department[]

  @@map("faculties")
}

model Department {
  id          String    @id @default(cuid())
  name        String
  nameAr      String?   @map("name_ar")
  code        String    @unique
  description String?   @db.LongText
  facultyId   String    @map("faculty_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  courses     Course[]
  faculty     Faculty   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  programs    Program[]
  professors  User[]    @relation("ProfessorDepartment")

  @@unique([facultyId, name])
  @@map("departments")
}

model Program {
  id                 String              @id @default(cuid())
  name               String
  nameAr             String?             @map("name_ar")
  code               String              @unique
  description        String?             @db.LongText
  creditHours        Int                 @default(132) @map("credit_hours")
  departmentId       String              @map("department_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  courses            Course[]
  programInstructors ProgramInstructor[]
  department         Department          @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  students           User[]              @relation("StudentProgram")

  @@unique([departmentId, name])
  @@map("programs")
}

model ProgramInstructor {
  id          Int      @id @default(autoincrement())
  assignedAt  DateTime @default(now()) @map("assigned_at")
  professorId String   @map("professor_id")
  programId   String   @map("program_id")
  professor   User     @relation(fields: [professorId], references: [id], onDelete: Cascade)
  program     Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([professorId, programId])
  @@index([programId], map: "program_instructors_program_id_fkey")
  @@map("program_instructors")
}

model User {
  id                   String              @id @default(cuid())
  email                String              @unique
  password             String
  name                 String
  nameAr               String?             @map("name_ar")
  avatar               String?
  phone                String?
  role                 UserRole            @default(STUDENT)
  studentId            String?             @unique @map("student_id")
  gpa                  Float?
  level                Int?
  programId            String?             @map("program_id")
  departmentId         String?             @map("department_id")
  isVerified           Boolean             @default(false) @map("is_verified")
  isOnboardingComplete Boolean             @default(false) @map("is_onboarding_complete")
  isActive             Boolean             @default(true) @map("is_active")
  faculty              String?
  major                String?
  semester             String?
  academicYear         String?             @map("academic_year")
  advisorName          String?             @map("advisor_name")
  advisorEmail         String?             @map("advisor_email")
  fcmToken             String?             @map("fcm_token")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  lastLoginAt          DateTime?           @map("last_login_at")
  address              String?             @db.Text
  departmentName       String?             @map("department_name")
  announcementsCreated Announcement[]
  contentCreated       CourseContent[]
  teachingCourses      CourseInstructor[]
  enrollments          Enrollment[]
  notes                Note[]
  notifications        Notification[]
  programsTeaching     ProgramInstructor[]
  scheduleEvents       ScheduleEvent[]
  taskSubmissions      TaskSubmission[]
  tasksCreated         Task[]              @relation("TaskCreator")
  umsCourses           UmsCourse[]
  umsGrades            UmsGrade[]
  umsSession           UmsSession?
  department           Department?         @relation("ProfessorDepartment", fields: [departmentId], references: [id])
  program              Program?            @relation("StudentProgram", fields: [programId], references: [id])
  verificationCodes    VerificationCode[]

  @@index([programId])
  @@index([departmentId])
  @@map("users")
}

model VerificationCode {
  id        Int              @id @default(autoincrement())
  code      String
  type      VerificationType
  expiresAt DateTime         @map("expires_at")
  used      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId], map: "verification_codes_user_id_fkey")
  @@map("verification_codes")
}

model Course {
  id            String             @id @default(cuid())
  code          String             @unique
  name          String
  nameAr        String?            @map("name_ar")
  description   String?            @db.LongText
  category      CourseCategory     @default(GENERAL)
  creditHours   Int                @default(3) @map("credit_hours")
  semester      String?
  academicYear  String?            @map("academic_year")
  isActive      Boolean            @default(true) @map("is_active")
  departmentId  String?            @map("department_id")
  programId     String?            @map("program_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  announcements Announcement[]
  content       CourseContent[]
  instructors   CourseInstructor[]
  scheduleSlots CourseSchedule[]
  department    Department?        @relation(fields: [departmentId], references: [id])
  program       Program?           @relation(fields: [programId], references: [id])
  enrollments   Enrollment[]
  tasks         Task[]

  @@index([departmentId])
  @@index([programId])
  @@map("courses")
}

model CourseInstructor {
  id         Int      @id @default(autoincrement())
  isPrimary  Boolean  @default(false) @map("is_primary")
  assignedAt DateTime @default(now()) @map("assigned_at")
  userId     String   @map("user_id")
  courseId   String   @map("course_id")
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId], map: "course_instructors_course_id_fkey")
  @@map("course_instructors")
}

model Enrollment {
  id          Int              @id @default(autoincrement())
  status      EnrollmentStatus @default(ENROLLED)
  enrolledAt  DateTime         @default(now()) @map("enrolled_at")
  completedAt DateTime?        @map("completed_at")
  grade       String?
  gradePoints Float?           @map("grade_points")
  userId      String           @map("user_id")
  courseId    String           @map("course_id")
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
  @@map("enrollments")
}

model CourseContent {
  id          String      @id @default(cuid())
  title       String
  description String?     @db.LongText
  contentType ContentType
  fileUrl     String?     @map("file_url")
  attachments Json?
  weekNumber  Int?        @map("week_number")
  orderIndex  Int         @default(0) @map("order_index")
  isPublished Boolean     @default(true) @map("is_published")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  courseId    String      @map("course_id")
  createdById String      @map("created_by_id")
  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy   User        @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([courseId, weekNumber])
  @@index([createdById], map: "course_content_created_by_id_fkey")
  @@map("course_content")
}

model CourseSchedule {
  id         Int       @id @default(autoincrement())
  dayOfWeek  DayOfWeek
  startTime  String    @map("start_time")
  endTime    String    @map("end_time")
  location   String?
  room       String?
  courseId   String    @map("course_id")
  lessonType String?   @default("LECTURE") @map("lesson_type")
  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId], map: "course_schedules_course_id_fkey")
  @@map("course_schedules")
}

model Task {
  id          String           @id @default(cuid())
  title       String
  description String?          @db.LongText
  taskType    TaskType         @default(ASSIGNMENT) @map("task_type")
  priority    TaskPriority     @default(MEDIUM)
  dueDate     DateTime?        @map("due_date")
  startDate   DateTime?        @map("start_date")
  maxPoints   Int              @default(100) @map("max_points")
  attachments Json?
  questions   Json?
  settings    Json?
  published   Boolean          @default(true)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  status      String           @default("PENDING")
  completedAt DateTime?        @map("completed_at")
  courseId    String?          @map("course_id")
  createdById String           @map("created_by_id")
  submissions TaskSubmission[]
  course      Course?          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy   User             @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([dueDate])
  @@index([courseId])
  @@index([createdById])
  @@index([status])
  @@index([createdById, status])
  @@map("tasks")
}

model TaskSubmission {
  id          String           @id @default(cuid())
  status      SubmissionStatus @default(PENDING)
  submittedAt DateTime?        @map("submitted_at")
  fileUrl     String?          @map("file_url")
  notes       String?          @db.LongText
  answers     Json?
  startedAt   DateTime?        @map("started_at")
  snapshots   Json?
  points      Float?
  grade       String?
  feedback    String?          @db.LongText
  gradedAt    DateTime?        @map("graded_at")
  taskId      String           @map("task_id")
  studentId   String           @map("student_id")
  student     User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  task        Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, studentId])
  @@index([studentId], map: "task_submissions_student_id_fkey")
  @@map("task_submissions")
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String?  @db.LongText
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notes")
}

model Announcement {
  id          String           @id @default(cuid())
  title       String
  message     String           @db.LongText
  type        AnnouncementType @default(GENERAL)
  isPinned    Boolean          @default(false) @map("is_pinned")
  createdAt   DateTime         @default(now()) @map("created_at")
  expiresAt   DateTime?        @map("expires_at")
  courseId    String?          @map("course_id")
  createdById String           @map("created_by_id")
  course      Course?          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy   User             @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([courseId], map: "announcements_course_id_fkey")
  @@index([createdById], map: "announcements_created_by_id_fkey")
  @@map("announcements")
}

model Notification {
  id            String           @id @default(cuid())
  title         String
  message       String           @db.LongText
  type          NotificationType @default(GENERAL)
  referenceType ReferenceType?   @map("reference_type")
  referenceId   String?          @map("reference_id")
  isRead        Boolean          @default(false) @map("is_read")
  isPushed      Boolean          @default(false) @map("is_pushed")
  createdAt     DateTime         @default(now()) @map("created_at")
  readAt        DateTime?        @map("read_at")
  userId        String           @map("user_id")
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model ScheduleEvent {
  id             String    @id @default(cuid())
  title          String
  description    String?   @db.LongText
  eventType      EventType @default(PERSONAL)
  startTime      DateTime  @map("start_time")
  endTime        DateTime  @map("end_time")
  isAllDay       Boolean   @default(false) @map("is_all_day")
  location       String?
  isRecurring    Boolean   @default(false) @map("is_recurring")
  recurrenceRule String?   @map("recurrence_rule")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([startTime])
  @@index([userId])
  @@map("schedule_events")
}

model UmsSession {
  id         Int       @id @default(autoincrement())
  cookies    Json
  lastSyncAt DateTime  @default(now()) @map("last_sync_at")
  expiresAt  DateTime? @map("expires_at")
  isActive   Boolean   @default(true) @map("is_active")
  userId     String    @unique @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ums_sessions")
}

model UmsCourse {
  id             Int      @id @default(autoincrement())
  courseCode     String   @map("course_code")
  courseName     String   @map("course_name")
  courseNameAr   String?  @map("course_name_ar")
  creditHours    Int?     @map("credit_hours")
  section        String?
  semester       String?
  academicYear   String?  @map("academic_year")
  instructorName String?  @map("instructor_name")
  rawData        Json?    @map("raw_data")
  syncedAt       DateTime @default(now()) @map("synced_at")
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseCode, semester, academicYear])
  @@index([userId])
  @@map("ums_courses")
}

model UmsGrade {
  id           Int      @id @default(autoincrement())
  courseCode   String   @map("course_code")
  courseName   String   @map("course_name")
  grade        String?
  gradePoints  Float?   @map("grade_points")
  creditHours  Int?     @map("credit_hours")
  semester     String?
  academicYear String?  @map("academic_year")
  rawData      Json?    @map("raw_data")
  syncedAt     DateTime @default(now()) @map("synced_at")
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseCode, semester, academicYear])
  @@index([userId])
  @@map("ums_grades")
}

enum UserRole {
  STUDENT
  PROFESSOR
  ADMIN
}

enum VerificationType {
  REGISTRATION
  PASSWORD_RESET
  EMAIL_CHANGE
}

enum CourseCategory {
  COMP
  MATH
  CHEM
  PHYS
  BIO
  GENERAL
  ELECTIVE
}

enum EnrollmentStatus {
  ENROLLED
  COMPLETED
  DROPPED
  WITHDRAWN
  FAILED
}

enum ContentType {
  LECTURE
  MATERIAL
  VIDEO
  DOCUMENT
  LINK
  GRADES
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum TaskType {
  ASSIGNMENT
  EXAM
  QUIZ
  PROJECT
  LAB
  PERSONAL
  GRADES
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SubmissionStatus {
  PENDING
  SUBMITTED
  LATE
  GRADED
  RETURNED
}

enum AnnouncementType {
  GENERAL
  ASSIGNMENT
  EXAM
  LECTURE
  GRADES
  URGENT
  MAINTENANCE
}

enum NotificationType {
  GENERAL
  ANNOUNCEMENT
  ASSIGNMENT
  EXAM
  GRADE
  REMINDER
  SYSTEM
}

enum ReferenceType {
  ANNOUNCEMENT
  TASK
  COURSE
  CONTENT
}

enum EventType {
  LECTURE
  EXAM
  ASSIGNMENT_DUE
  MEETING
  OFFICE_HOURS
  PERSONAL
}
